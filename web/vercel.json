{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/", "destination": "/home.html" },
    { "source": "/coverage", "destination": "/coverage.html" },
    { "source": "/ledger", "destination": "/ledger.html" },
    { "source": "/proof", "destination": "/proof.html" },
    { "source": "/providers", "destination": "/providers.html" },
    { "source": "/simulate", "destination": "/index.html" },
    { "source": "/console", "destination": "/index.html" },
    { "source": "/registry", "destination": "/index.html" },
    { "source": "/receipts", "destination": "/index.html" },
    { "source": "/agent", "destination": "/home.html" }
  ]
}
