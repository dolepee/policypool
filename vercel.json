{
  "version": 2,
  "builds": [
    {
      "src": "api/coverage-demand.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/coverage-ledger.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/coverage-preflight.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/coverage-status.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/covered-job-receipt.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/manifest.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/provider-bond.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/provider-enrollment.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/provider-relay.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/reconcile-coverage.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/v04-runtime.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/record-payout.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/direct-a2mcp",
      "dest": "/api/v04-runtime.js?surface=direct-a2mcp"
    },
    {
      "src": "/api/reconcile-direct-a2mcp",
      "dest": "/api/v04-runtime.js?surface=reconcile-direct-a2mcp"
    },
    {
      "src": "/api/reconcile-universal",
      "dest": "/api/v04-runtime.js?surface=reconcile-universal"
    },
    {
      "src": "/api/universal-manifest",
      "dest": "/api/manifest.js?surface=universal"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/.well-known/policypool.json",
      "dest": "/api/manifest.js"
    },
    {
      "src": "^/$",
      "dest": "/web/home.html"
    },
    {
      "src": "/agent",
      "dest": "/web/home.html"
    },
    {
      "src": "/coverage",
      "dest": "/web/coverage.html"
    },
    {
      "src": "/ledger",
      "dest": "/web/ledger.html"
    },
    {
      "src": "/proof",
      "dest": "/web/proof.html"
    },
    {
      "src": "/providers",
      "dest": "/web/providers.html"
    },
    {
      "src": "/providers/enroll",
      "dest": "/web/enroll.html"
    },
    {
      "src": "/hook",
      "dest": "/web/index.html"
    },
    {
      "src": "/(.*\\.(?:css|js|svg|png|ico|json|txt|xml))",
      "dest": "/web/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
