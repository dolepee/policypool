{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/.well-known/policypool.json",
      "dest": "/api/manifest.js"
    },
    {
      "src": "^/$",
      "dest": "/web/home.html"
    },
    {
      "src": "/agent",
      "dest": "/web/home.html"
    },
    {
      "src": "/coverage",
      "dest": "/web/coverage.html"
    },
    {
      "src": "/ledger",
      "dest": "/web/ledger.html"
    },
    {
      "src": "/proof",
      "dest": "/web/proof.html"
    },
    {
      "src": "/providers",
      "dest": "/web/providers.html"
    },
    {
      "src": "/hook",
      "dest": "/web/index.html"
    },
    {
      "src": "/(.*\\.(?:css|js|svg|png|ico|json|txt|xml))",
      "dest": "/web/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
